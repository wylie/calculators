---
import MainLayout from '../layouts/MainLayout.astro';
import CookingConverterPage from '../react-pages/CookingConverter/CookingConverterPage';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why do recipes use different units?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Recipes come from different regions. US uses cups, most others use grams for accuracy. Grams is more precise.',
      },
    },
    {
      '@type': 'Question',
      name: 'How many tablespoons are in 1/4 cup?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '1/4 cup equals 4 tablespoons.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I enter fractions like 1/2?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The converter supports fractions and mixed numbers, such as 1/2 and 1 1/2.',
      },
    },
  ],
};
---

<MainLayout
  title="Cooking Converter - Cups, Tbsp, Tsp, ml"
  description="Convert kitchen volume measurements fast, including cups, tablespoons, teaspoons, milliliters, and fluid ounces."
  jsonLd={faqSchema}
>
  <CookingConverterPage client:load />
</MainLayout>
