---
import MainLayout from '../layouts/MainLayout.astro';
import InvestmentGrowthPage from '../react-pages/InvestmentGrowth/InvestmentGrowthPage';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does compound growth work in this calculator?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The estimate compounds investment returns over time and includes the effect of recurring monthly contributions.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is included in total invested amount?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Total invested is your initial amount plus all monthly contributions over the selected years.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is return rate guaranteed?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Return assumptions are hypothetical estimates and real market performance can vary year to year.',
      },
    },
  ],
};
---

<MainLayout
  title="Investment Growth"
  description="Estimate future investment value with compound growth, monthly contributions, expected returns, and time horizon."
  jsonLd={faqSchema}
>
  <InvestmentGrowthPage client:load />

  <section class="mt-8 space-y-6" aria-label="Investment growth methodology and guidance">
    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">Methodology</h2>
      <p class="text-sm text-slate-600">
        This calculator projects portfolio value by combining initial principal, recurring contributions, and compound
        return assumptions across the selected horizon.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Assumptions</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>Contributions are made consistently at the chosen interval.</li>
        <li>Return rate is an average annualized estimate.</li>
        <li>Taxes, investment fees, and contribution limits are not automatically deducted.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Worked example</h2>
      <p class="text-sm text-slate-600">
        Example: $25,000 starting balance with $500 monthly contributions at 6.5% expected return over 15 years. The
        tool estimates ending value, total contributions, and growth attributable to returns.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Edge cases and limitations</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>Real markets are volatile, and sequence-of-returns risk is not modeled directly.</li>
        <li>Short periods can diverge significantly from expected averages.</li>
        <li>Inflation is not implicit unless you manually reduce return assumptions.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">When this calculator is not appropriate</h2>
      <p class="text-sm text-slate-600">
        For retirement drawdown, tax-efficient withdrawal strategy, or risk-based planning, use a full financial plan
        with a licensed advisor.
      </p>
    </article>
  </section>
</MainLayout>
