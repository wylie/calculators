---
import MainLayout from '../layouts/MainLayout.astro';
import CompoundInterestPage from '../react-pages/CompoundInterest/CompoundInterestPage';
import AffiliateBox from '../components/AffiliateBox';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is compound interest?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Compound interest means interest is earned on both original principal and previously accumulated interest.',
      },
    },
    {
      '@type': 'Question',
      name: 'How often should I compound in the calculator?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Use the compounding frequency that best matches your account terms, such as monthly, quarterly, or annually.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are returns guaranteed?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Investment returns are uncertain. This tool provides hypothetical projections based on your input assumptions.',
      },
    },
  ],
};
---

<MainLayout
  title="Compound Interest Calculator"
  description="Project future balance with compounding frequency, contribution schedule, and time horizon assumptions."
  jsonLd={faqSchema}
  showAffiliate={false}
>
  <CompoundInterestPage client:load />
  <AffiliateBox pageUrl={Astro.url.pathname} client:load />

  <section class="mt-8 space-y-6" aria-label="Compound interest methodology and guidance">
    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">Methodology</h2>
      <p class="text-sm text-slate-600">
        The calculator applies periodic compounding to your principal and recurring contributions. Growth is modeled from
        your expected annual return and selected compounding frequency.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Assumptions</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>Return rate is constant over the full time horizon.</li>
        <li>Contributions happen on schedule without interruption.</li>
        <li>No taxes, fees, or account minimum constraints are deducted unless manually adjusted in assumptions.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Worked example</h2>
      <p class="text-sm text-slate-600">
        Example: $10,000 initial amount, $300 monthly contribution, 7% annual return, monthly compounding, 20 years.
        The ending balance reflects compounded growth from both principal and contributions.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Edge cases and limitations</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>Short horizons can be dominated by contribution amount rather than compounding effect.</li>
        <li>High assumed returns can overstate outcomes if market volatility is ignored.</li>
        <li>Taxes and fund fees can materially reduce real-world ending value.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">When this calculator is not appropriate</h2>
      <p class="text-sm text-slate-600">
        This is not a replacement for investment advice or retirement planning software that models variable returns,
        sequence risk, taxes, and withdrawal strategies.
      </p>
    </article>
  </section>
</MainLayout>
