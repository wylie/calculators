---
import MainLayout from '../layouts/MainLayout.astro';
import CreditCardPayoffPage from '../react-pages/CreditCardPayoff/CreditCardPayoffPage';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does credit card payoff time get calculated?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The calculator uses your balance, APR, and monthly payment to estimate the number of months required to pay the debt to zero.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my monthly payment is too low?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'If payment is very low relative to APR, payoff can take much longer and total interest can become very high.',
      },
    },
    {
      '@type': 'Question',
      name: 'How can I reduce total interest paid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Increase monthly payments, reduce APR through refinancing or transfers, and avoid adding new balances during payoff.',
      },
    },
  ],
};
---

<MainLayout
  title="Credit Card Payoff"
  description="Estimate credit card payoff timeline, total interest, and total paid based on balance, APR, and monthly payment."
  jsonLd={faqSchema}
>
  <CreditCardPayoffPage client:load />

  <section class="mt-8 space-y-6" aria-label="Credit card payoff methodology and guidance">
    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-3">
      <h2 class="text-xl font-semibold text-slate-900">Methodology</h2>
      <p class="text-sm text-slate-600">
        The calculator estimates month-by-month payoff using current balance, APR, and payment amount. Interest accrues
        each period and remaining balance updates until paid off.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Assumptions</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>No new purchases are added during payoff.</li>
        <li>APR stays constant and no promotional periods expire mid-plan.</li>
        <li>Payment is made on time each month.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Worked example</h2>
      <p class="text-sm text-slate-600">
        Example: $8,000 balance at 22% APR with a $300 monthly payment. The calculator shows estimated payoff months,
        total interest, and how increasing payment changes total cost.
      </p>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">Edge cases and limitations</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
        <li>If payment is below monthly interest, balance may not decline meaningfully.</li>
        <li>Balance transfer fees and promo APR expiration can change results.</li>
        <li>Late fees or penalty APR are not modeled unless included manually.</li>
      </ul>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm space-y-2">
      <h2 class="text-xl font-semibold text-slate-900">When this calculator is not appropriate</h2>
      <p class="text-sm text-slate-600">
        Complex multi-card payoff strategies may require a debt snowball or avalanche planner with card-by-card details.
      </p>
    </article>
  </section>
</MainLayout>
