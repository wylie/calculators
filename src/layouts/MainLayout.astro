---
import '../index.css';
import Nav from '../components/Nav.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import AffiliateBox from '../components/AffiliateBox';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  showAffiliate?: boolean;
}

const siteUrl = 'https://simplecalculators.io';
const siteName = 'Simple Calculators';
const { title, description, canonical, image, noindex = false, jsonLd, showAffiliate = true } = Astro.props;
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const defaultDescription = 'Free online calculators and converters for mortgage, budget, weather, calories, and more. Simple, accurate, and easy to use.';
const pageDescription = description || defaultDescription;
const pageTitle = `${title} | ${siteName}`;
const ogSlug = Astro.url.pathname === '/' ? 'home' : Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '');
const ogImage = image || (Astro.url.pathname === '/' ? `${siteUrl}/og-image.png` : `${siteUrl}/og/${ogSlug}.svg`);
const isToolPage = /calculator|converter/i.test(title);
const breadcrumbItems = Astro.url.pathname === '/'
  ? [{ '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` }]
  : [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: title, item: canonicalUrl },
    ];

const baseJsonLd: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: `${siteUrl}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: canonicalUrl,
    isPartOf: {
      '@type': 'WebSite',
      name: siteName,
      url: `${siteUrl}/`,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems,
  },
];

if (isToolPage) {
  baseJsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: title,
    applicationCategory: title.toLowerCase().includes('converter') ? 'UtilitiesApplication' : 'FinanceApplication',
    operatingSystem: 'Any',
    isAccessibleForFree: true,
    url: canonicalUrl,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  });

  baseJsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    description: pageDescription,
    author: {
      '@type': 'Organization',
      name: siteName,
    },
    publisher: {
      '@type': 'Organization',
      name: siteName,
    },
    dateModified: '2026-02-18',
    mainEntityOfPage: canonicalUrl,
  });
}

const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...baseJsonLd, ...pageJsonLd];
const cloudflareWebAnalyticsToken = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-7Z9DM31C5W';
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>(function(s){s.dataset.zone='10756924',s.src='https://nap5k.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    
    <!-- Google Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    
    <!-- Google Analytics 4 -->
    {gaMeasurementId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>}
    <script is:inline define:vars={{ gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      const gaParams = new URLSearchParams(window.location.search);
      const gaDebugMode = gaParams.get('ga_debug') === '1';
      const gaHealthMode = gaParams.get('ga_health') === '1' || gaDebugMode;

      const gaHealth = window.__gaHealth || {
        measurementId: gaMeasurementId,
        initializedAt: new Date().toISOString(),
        callCount: 0,
        configCount: 0,
        pageViewCount: 0,
        lastCommand: 'none',
        lastCommandAt: undefined,
        healthMode: gaHealthMode,
      };
      gaHealth.healthMode = gaHealthMode;
      window.__gaHealth = gaHealth;

      window.gtag = window.gtag || function () {
        window.dataLayer.push(arguments);

        const command = arguments[0];
        const eventName = arguments[1];
        gaHealth.callCount += 1;
        gaHealth.lastCommand = `${command}${eventName ? `:${eventName}` : ''}`;
        gaHealth.lastCommandAt = new Date().toISOString();
        if (command === 'config') {
          gaHealth.configCount += 1;
        }
        if (command === 'event' && eventName === 'page_view') {
          gaHealth.pageViewCount += 1;
        }
      };

      window.gtag('js', new Date());
      window.gtag('config', gaMeasurementId, {
        anonymize_ip: true,
        allow_google_signals: false,
        allow_ad_personalization_signals: false,
        debug_mode: gaDebugMode,
      });

      window.gtag('event', 'page_view', {
        page_title: document.title,
        page_location: window.location.href,
        page_path: window.location.pathname,
      });
    </script>
    <script is:inline define:vars={{ gaMeasurementId }}>
      (function () {
        if (typeof window === 'undefined') return;
        const params = new URLSearchParams(window.location.search);
        const healthEnabled = params.get('ga_health') === '1' || params.get('ga_debug') === '1';
        if (!healthEnabled) return;

        const makeBadge = () => {
          const existing = document.getElementById('ga-health-badge');
          if (existing) return existing;

          if (!document.body) return null;

          const badge = document.createElement('div');
          badge.id = 'ga-health-badge';
          badge.setAttribute('aria-live', 'polite');
          badge.style.position = 'fixed';
          badge.style.top = '12px';
          badge.style.right = '12px';
          badge.style.zIndex = '9999';
          badge.style.background = '#0f172a';
          badge.style.color = '#e2e8f0';
          badge.style.border = '1px solid #334155';
          badge.style.borderRadius = '8px';
          badge.style.padding = '8px 10px';
          badge.style.fontSize = '11px';
          badge.style.fontFamily = 'Inter, system-ui, sans-serif';
          badge.style.lineHeight = '1.3';
          badge.style.minWidth = '210px';
          badge.style.boxShadow = '0 6px 18px rgba(0,0,0,0.25)';
          document.body.appendChild(badge);
          return badge;
        };

        const render = (badge) => {
          if (!badge) return;
          const health = window.__gaHealth || {};
          const stats = window.__gaDebugStats || {};
          const gtagReady = typeof window.gtag === 'function';
          const hasTagManager = !!window.google_tag_manager;
          const dataLayerLength = Array.isArray(window.dataLayer) ? window.dataLayer.length : 0;
          const attempted = stats.attempted ?? 0;
          const sent = stats.sent ?? 0;
          const blockedNoGtag = stats.blockedNoGtag ?? 0;
          const blockedDisabled = stats.blockedDisabled ?? 0;
          const lastEvent = stats.lastEvent || 'none';
          const healthLastCommand = health.lastCommand || 'none';
          const configCount = health.configCount ?? 0;
          const pageViewCount = health.pageViewCount ?? 0;
          const gtagStatus = gtagReady ? (hasTagManager ? 'ready' : 'stub') : 'missing';

          badge.innerHTML = [
            '<strong style="color:#93c5fd">GA Health (temporary)</strong>',
            `stream: ${gaMeasurementId}`,
            `gtag: ${gtagStatus}`,
            `dlayer: ${dataLayerLength}`,
            `config/page_view: ${configCount}/${pageViewCount}`,
            `sent: ${sent}/${attempted}`,
            `blocked: ngtag=${blockedNoGtag}, off=${blockedDisabled}`,
            `last cmd/event: ${healthLastCommand} / ${lastEvent}`,
          ].join('<br>');
        };

        const mount = () => {
          const badge = makeBadge();
          if (!badge) return;
          render(badge);
          window.setInterval(() => render(badge), 2000);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', mount, { once: true });
        } else {
          mount();
        }
      })();
    </script>

    <!-- Cloudflare Web Analytics (optional) -->
    {import.meta.env.PROD && cloudflareWebAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareWebAnalyticsToken })}
      ></script>
    )}

    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-slate-50">
      <header class="sticky top-0 z-40">
        <Nav />
      </header>
      <main class="flex-1 max-w-4xl w-full mx-auto px-4 py-8">
        <slot />
        {showAffiliate && <AffiliateBox pageUrl={Astro.url.pathname} client:load />}
      </main>
      <ConsentBanner />
      <footer class="border-t border-slate-200 bg-white py-6 mt-12">
        <div class="max-w-4xl mx-auto px-4 text-center text-xs text-slate-600">
          <p class="mb-2">
            Disclaimer: These calculators provide estimates for educational purposes only. They are not
            financial or medical advice. Please consult with a qualified professional for
            personalized guidance.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3 mb-2">
            <a href="/about" class="text-xs text-slate-600 hover:text-slate-900 underline">About</a>
            <a href="/editorial-policy" class="text-xs text-slate-600 hover:text-slate-900 underline">Editorial Policy</a>
            <a href="/methodology" class="text-xs text-slate-600 hover:text-slate-900 underline">Methodology</a>
            <a href="/privacy" class="text-xs text-slate-600 hover:text-slate-900 underline">Privacy Policy</a>
            <a href="/terms" class="text-xs text-slate-600 hover:text-slate-900 underline">Terms</a>
            <a href="/accessibility" class="text-xs text-slate-600 hover:text-slate-900 underline">Accessibility</a>
            <a href="/contact" class="text-xs text-slate-600 hover:text-slate-900 underline">Contact</a>
          </div>
          <p>Simple Calculators 2026. All rights reserved.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
